{
  "tools": [
    {
      "name": "claude",
      "command": "claude",
      "description": "Anthropic Claude CLI",
      "aliases": ["c"]
    },
    {
      "name": "opencode",
      "command": "opencode",
      "description": "OpenCode AI assistant",
      "aliases": ["o", "oc"]
    },
    {
      "name": "copilot",
      "command": "copilot",
      "description": "GitHub Copilot CLI",
      "aliases": ["cp"]
    },
    {
      "name": "amp",
      "command": "amp",
      "description": "Frontier coding agent for terminal and editor",
      "aliases": ["a"]
    },
    {
      "name": "codex",
      "command": "codex",
      "description": "OpenAI Codex CLI",
      "aliases": ["cx"]
    }
  ],
  "templates": [
    {
      "name": "summarize",
      "command": "claude --print --model haiku 'Summarize the following file: $@'",
      "description": "Summarize a file with Claude",
      "aliases": ["sum", "summary"],
      "mode": "read-only",
      "requiresConfirmation": false
    },
    {
      "name": "review",
      "command": "amp -x 'Review this code: $@'",
      "description": "Code review with Amp",
      "aliases": ["rev", "code-review"],
      "mode": "read-only",
      "requiresConfirmation": false
    },
    {
      "name": "commit-zen",
      "command": "opencode run --model opencode/big-pickle --agent plan 'Review the following changes and generate a concise git commit message: $@'",
      "description": "Generate commit message with OpenCode",
      "aliases": ["commit", "commit-message"],
      "mode": "write",
      "requiresConfirmation": true
    }
  ],
  "router": {
    "command": "opencode run --model opencode/big-pickle --agent plan",
    "description": "Route free-form task descriptions to the best template",
    "promptUseStdin": true
  }
}
